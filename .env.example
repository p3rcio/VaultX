# API
# Port the Express API runs on
API_PORT=4000

# Database
# Must match POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB in infra/docker-compose.yml
DATABASE_URL=postgresql://vaultx:vaultx_secret@localhost:5432/vaultx

# JWT
# Used to sign auth tokens — make up any long random string (32+ characters)
# Example generator: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# CORS
# URL of the frontend — must match where Next.js is running
CORS_ORIGIN=http://localhost:3000

# Next.js public variables (exposed to the browser)
# Must match API_PORT and MINIO_PORT above
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# MinIO (S3-compatible file store)
# Must match MINIO_ROOT_USER and MINIO_ROOT_PASSWORD in infra/docker-compose.yml
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vaultx-files
MINIO_USE_SSL=false
